[logging]
level = "info"

[proxy]
active_upstream = "deepseek"
hook_store_capacity = 1000
mcp_store_capacity = 500
request_store_capacity = 1000

[[proxy.upstreams]]
name = "deepseek"
url = "https://api.deepseek.com/anthropic"

# Translate Claude model names → upstream equivalents.
# Keys use prefix matching: "claude-sonnet-4-6" matches "claude-sonnet-4-6-20250514" etc.
# [1m] suffix is preserved automatically.
[proxy.upstreams.model_map]
"claude-sonnet-4-6" = "deepseek-v4-pro"
"claude-opus-4-6" = "deepseek-v4-pro[1m]"
"claude-haiku-4-5" = "deepseek-chat"

[[proxy.upstreams]]
name = "anthropic"
url = "https://api.anthropic.com"

[server]
http_port = 5000
listen_address = "127.0.0.1"
mcp_proxy_port = 9999
proxy_port = 8888

[logging]
level = "info"

[proxy]
active_upstream = "deepseek"
hook_store_capacity = 1000
mcp_store_capacity = 500
request_retention_hours = 8
request_store_capacity = 1000
session_max_count = 2000

[[proxy.providers]]
name = "deepseek"
url = "https://api.deepseek.com/anthropic"

[[proxy.providers.models]]
id = "deepseek-v4-pro"
price_per_million_input = 3.0
price_per_million_output = 6.0

[[proxy.providers.models]]
id = "deepseek-v4-flash"
price_per_million_input = 1.0
price_per_million_output = 2.0

[[proxy.upstreams]]
default_model = "deepseek-v4-pro"
default_provider = "deepseek"
name = "deepseek"

[proxy.upstreams.high]
keywords = ["opus"]
model = "deepseek-v4-pro"
provider = "deepseek"

[proxy.upstreams.low]
keywords = ["haiku"]
model = "deepseek-v4-pro"
provider = "deepseek"

[proxy.upstreams.mid]
keywords = ["sonnet"]
model = "deepseek-v4-pro"
provider = "deepseek"

[server]
http_port = 5000
listen_address = "127.0.0.1"
mcp_proxy_port = 9999
proxy_port = 8888
